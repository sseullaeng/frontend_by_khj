# 백엔드 API 기본 URL
VITE_API_BASE=http://localhost:8080

# WebSocket (STOMP) 엔드포인트
VITE_WS_URL=ws://localhost:8080/ws-stomp

# 카카오맵 JavaScript API 키
VITE_KAKAO_MAP_KEY=your_kakao_map_api_key

# 카카오 로그인 JavaScript 앱 키 (SDK 초기화용)
# 토큰 교환은 백엔드 위임이므로 REST API 키는 프론트에 두지 않음
VITE_KAKAO_JS_KEY=your_kakao_javascript_app_key

# 구글 OAuth 2.0 클라이언트 ID (Web)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# 토스 결제 클라이언트 키
VITE_TOSS_CLIENT_KEY=test_ck_your_toss_client_key
