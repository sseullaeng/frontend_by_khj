# 백엔드 API 기본 URL
VITE_API_BASE=http://localhost:8080

# WebSocket (STOMP) 엔드포인트
VITE_WS_URL=ws://localhost:8080/ws-stomp

# 카카오 JavaScript 앱 키
# 같은 키 하나로 사용: 카카오 로그인 SDK + 카카오맵 + 로컬 검색 (Places/Geocoder)
# 라운드14 — 카카오맵 / 로그인을 *다른 디벨로퍼 앱* 으로 분리하려면 아래 두 변수 사용.
#   VITE_KAKAO_MAP_JS_KEY  : 카카오맵 + 로컬검색(Places/Geocoder) 전용 앱 키
#   VITE_KAKAO_AUTH_JS_KEY : 카카오 로그인 전용 앱 키 (비즈앱 + 검수 통과)
# 둘 다 비어있으면 VITE_KAKAO_JS_KEY 로 fallback.
VITE_KAKAO_JS_KEY=your_kakao_javascript_app_key
# VITE_KAKAO_MAP_JS_KEY=your_kakao_map_app_javascript_key
# VITE_KAKAO_AUTH_JS_KEY=your_kakao_login_app_javascript_key

# 구글 OAuth 2.0 클라이언트 ID (Web)
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id

# 토스 결제 클라이언트 키
VITE_TOSS_CLIENT_KEY=test_ck_your_toss_client_key
